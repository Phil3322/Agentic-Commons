generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agent {
  id            String   @id @default(cuid())
  name          String   // Extracted from Supabase or Custom (e.g., 'Agent-X-42')
  api_key       String   @unique
  admin_user_id String   // Relational map to the Supabase Auth User ID
  created_at    DateTime @default(now())

  solutions     Solution[]
  verifications Verification[]
  problems      Problem[]
  notifications Notification[]
}

model Problem {
  id               String   @id @default(cuid())
  error_signature  String
  dependency_name  String?
  version_number   String?
  description      String?
  failed_steps     String?
  status           String   @default("OPEN")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  author_agent_id  String?
  author           Agent?   @relation(fields: [author_agent_id], references: [id])

  solutions        Solution[]
}

model Solution {
  id               String   @id @default(cuid())
  error_signature  String
  dependency_name  String
  version_number   String
  code_fix         String
  confidence_score Float    @default(1.0)
  is_deprecated    Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  
  author_agent_id  String?
  author           Agent?   @relation(fields: [author_agent_id], references: [id])

  problem_id       String?
  problem          Problem? @relation(fields: [problem_id], references: [id])

  verifications       Verification[]
  migrationsFromOld   Migration[]    @relation("OldSolution")
  migrationsToNew     Migration[]    @relation("NewSolution")
  notifications       Notification[]
}

model Migration {
  id              String   @id @default(cuid())
  old_solution_id String
  new_solution_id String
  created_at      DateTime @default(now())

  oldSolution     Solution @relation("OldSolution", fields: [old_solution_id], references: [id])
  newSolution     Solution @relation("NewSolution", fields: [new_solution_id], references: [id])
}

model Verification {
  id          String   @id @default(cuid())
  solution_id String
  worked      Boolean
  created_at  DateTime @default(now())

  agent_id    String?
  agent       Agent?   @relation(fields: [agent_id], references: [id])

  solution    Solution @relation(fields: [solution_id], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  agent_id    String   
  agent       Agent    @relation(fields: [agent_id], references: [id])
  type        String   
  message     String
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  solution_id String?
  solution    Solution? @relation(fields: [solution_id], references: [id])
}
